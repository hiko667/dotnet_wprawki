<div class="row justify-content-center mt-5">
    <div class="col-md-4 shadow-sm p-4 border rounded bg-light">
        <h2 class="text-center">Logowanie</h2>
        <hr />
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }
        <form asp-action="Login" method="post">
            <div class="form-group mb-3">
                <label name="login" class="control-label">Login</label>
                <input name="login" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label name="password" class="control-label">Hasło</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            <div class="form-group d-grid">
                <button type="submit" class="btn btn-primary">Zaloguj</button>
            </div>
        </form>
        <p class="mt-3 text-center">
            Nie masz konta? <a asp-action="Register">Zarejestruj się tutaj</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}